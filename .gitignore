# Secrets — never commit
.env
# .env above only matches a file named exactly `.env`. Block all env variants
# and backups so the auto-snapshot robot (git add -A) can't commit secrets.
# The .env.pre-phase2-2026-05-11.bak leak (2026-05-30) is why these exist.
.env.*
*.bak
!.env.example
!**/.env.example

# Log archives
logs/archive/

# Temp files
*.tmp
*.log

# Node
node_modules/

# ChatGPT MCP runtime artifacts
chatgpt-mcp/.terminal-insights.md

# OS
.DS_Store

# Python
__pycache__/
*.pyc
.venv/

# Runtime state
*.pid
.dispatcher.pid
.queue-runner.pid
.queue-empty-notified

# Claude worktrees
.claude/worktrees/

# Embedded repos (separate git repos)
clawmpson-logs/
doctor-claw/
punch-my-baby/
shiny-new/
openclaw-build/
logs/*.jsonl
