# Instagram Crawler -- Environment Variables
# Copy to .env and adjust as needed.

# --- Instagram Graph API (optional — enables API mode) ---
# Get a token via Facebook Developer Portal -> Graph API Explorer
# Requires an Instagram Business/Creator account connected to a Facebook Page
# INSTAGRAM_ACCESS_TOKEN=your_token_here

# --- User agent (optional, has default) ---
# INSTAGRAM_USER_AGENT=Mozilla/5.0 (compatible; openclaw-instagram-crawler/0.1)

# --- Polling intervals in seconds ---
HASHTAG_INTERVAL_SEC=3600
PROFILE_INTERVAL_SEC=86400

# --- Crawl limits ---
POSTS_PER_HASHTAG=30

# --- Rate limiting (seconds between requests) ---
REQUEST_DELAY_MIN=3.0
REQUEST_DELAY_MAX=5.0

# --- Logging ---
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
